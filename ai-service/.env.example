# ═══════════════════════════════════════════════════════════
#  backend/.env  —  Variables d'environnement du serveur
#  Copiez ce fichier en ".env" et remplissez les valeurs.
#  NE COMMITEZ JAMAIS votre .env dans Git.
# ═══════════════════════════════════════════════════════════


# ── Serveur ──────────────────────────────────────────────────
PORT=4000
# Port d'écoute du serveur Express.
# Le frontend Vite proxy /api vers http://localhost:4000 automatiquement.

NODE_ENV=development
# "development" active les messages d'erreur détaillés.
# Mettez "production" lors du déploiement.


# ── Base de données MySQL (XAMPP) ────────────────────────────
DB_HOST=127.0.0.1
# Adresse du serveur MySQL. Avec XAMPP, c'est toujours 127.0.0.1.

DB_PORT=3306
# Port MySQL par défaut. Ne changez pas sauf si vous avez modifié la config XAMPP.

DB_NAME=ai_doc_orchestrator
# Nom de la base de données créée par le script database/schema.sql.

DB_USER=root
# Utilisateur MySQL. Avec XAMPP : "root" par défaut.

DB_PASSWORD=
# Mot de passe MySQL. Avec XAMPP : laissez vide par défaut.
# En production, définissez un vrai mot de passe ici.


# ── JWT (authentification) ───────────────────────────────────
JWT_SECRET=d6481a980153d6e28ec705acef2eb0c31778b2cd857454357abb8ad73a7622e8
# Clé secrète pour signer les tokens JWT.
# En production : générez avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# IMPORTANT : si vous changez cette valeur, tous les utilisateurs seront déconnectés.

JWT_EXPIRES_IN=8h
# Durée de validité d'un token. "8h" = 8 heures.
# Autres exemples : "1d" (1 jour), "30m" (30 minutes).


# ── SMTP (envoi d'emails réels) ──────────────────────────────
# Exemple avec Gmail + App Password (recommandé pour les tests) :
#
# 1. Activez la validation en 2 étapes sur votre compte Google.
# 2. Allez sur https://myaccount.google.com/apppasswords
# 3. Créez un "App Password" pour "Mail" → copiez le mot de passe généré (16 caractères).
# 4. Remplissez SMTP_USER avec votre adresse Gmail et SMTP_PASS avec ce mot de passe.

SMTP_HOST=smtp.gmail.com
# Serveur SMTP de Gmail.
# Pour Office 365 : smtp.office365.com
# Pour un serveur SMTP local (MailHog) : localhost

SMTP_PORT=587
# Port SMTP avec STARTTLS (recommandé).
# Port 465 = SSL direct (changez aussi SMTP_SECURE=true).

SMTP_SECURE=false
# "false" avec port 587 (STARTTLS).
# "true" avec port 465 (SSL direct).

SMTP_USER=votre.adresse@gmail.com
# Adresse email utilisée pour envoyer les emails.

SMTP_PASS=votre_app_password_ici
# Mot de passe d'application Gmail (PAS votre mot de passe Gmail normal).

SMTP_FROM="CGI Consultant Tool <vianney.demaximy@edu.ece.fr>"
# Nom et adresse affichés dans le champ "De :" des emails envoyés.


# ── Service IA ───────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
# URL du service FastAPI Python.
# Ne changez que si vous l'exécutez sur un autre port ou serveur.


# ── CORS (sécurité navigateur) ───────────────────────────────
FRONTEND_URL=http://localhost:5173
# URL du frontend React (Vite).
# En production, mettez l'URL publique : https://votre-domaine.com
